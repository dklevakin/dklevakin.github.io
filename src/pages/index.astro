---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout
  title="Dmytro Klevakin — Cloud Solution Architect"
  description="Azure Solutions Lead with 13+ years designing cloud-native systems. Architect by day, automator by evening, live-coding musician by night."
>
  <!-- HERO — two-column layout -->
  <section class="page hero">
    <div class="wrap">
      <div class="hero-grid">

        <!-- Left: text -->
        <div class="hero-text">
          <div class="eyebrow">Dmytro Klevakin · Dnipro, Ukraine</div>
          <h1 style="margin-top:18px">Architect <em>as a</em><br><u>lifestyle</u>.</h1>
          <p class="lead" style="margin-top:28px">
            I'm an Azure Solutions Lead at SoftServe with 13+ years designing
            cloud-native systems across Azure, AWS and GCP. I make complex platforms
            <em style="font-style:italic;color:var(--navy-accent)">calm</em> — and I write down what I learn at <code>klevakin.com</code>.
          </p>

          <!-- Trust strip -->
          <div class="trust-strip">
            <span>✓ Microsoft AZ-400</span>
            <span class="sep">·</span>
            <span>13+ years</span>
            <span class="sep">·</span>
            <span>SoftServe CoE</span>
            <span class="sep">·</span>
            <span>NLP Master</span>
            <span class="sep">·</span>
            <span>Coach</span>
          </div>

          <div class="meta">
            <span class="pill"><span class="dot live"></span>Open for short engagements</span>
            <span class="pill"><span class="dot"></span>Azure · AWS · GCP</span>
            <span class="pill"><span class="dot"></span>Based in Dnipro 🇺🇦</span>
          </div>
          <div class="cta-row">
            <a class="btn gold" href="mailto:dlklevakin@gmail.com">Write me an email →</a>
            <a class="btn ghost" href="/projects">See projects</a>
          </div>
        </div>

        <!-- Right: portrait -->
        <div class="hero-portrait-wrap">
          <div class="portrait-frame">
            <div class="portrait-inner">
              <img
                class="photo"
                src="/assets/photo.png"
                alt="Dmytro Klevakin — Cloud Solution Architect"
                loading="eager"
              />
              <div class="portrait-watermark" aria-hidden="true">DK</div>
            </div>
            <!-- Decorative elements -->
            <div class="portrait-corner-tl" aria-hidden="true"></div>
            <div class="portrait-accent"    aria-hidden="true"></div>
          </div>
        </div>

      </div>

      <!-- BENTO GRID -->
      <div class="bento" aria-label="At a glance">
        <div class="card span2 row2">
          <div>
            <div class="lbl">Experience</div>
            <div class="num">13+</div>
          </div>
          <div class="lbl">years across Cloud · DevOps · Architecture roles, mostly at SoftServe</div>
        </div>
        <div class="card span2 navy">
          <div class="lbl">Primary cloud</div>
          <div class="num" style="font-size:36px">Microsoft Azure</div>
        </div>
        <div class="card span2">
          <div class="lbl">Certifications</div>
          <div class="num" style="font-size:30px">AZ-400</div>
          <div class="lbl">+ NLP Master Practitioner · Professional Coach</div>
        </div>
        <div class="card span2 gold">
          <div class="now-now"><span class="blink"></span>Now</div>
          <div style="font-size:14px;line-height:1.45">
            Leading the Azure CoE — Critical Services at SoftServe.
            Live-coding music with Strudel on weekends.
          </div>
        </div>
        <div class="card span4">
          <div class="lbl">What this site is</div>
          <div style="font-family:var(--serif);font-size:22px;line-height:1.3;font-weight:400;color:var(--ink)">
            A logbook for cloud, automation and AI — plus a corner for the music I make outside work.
          </div>
        </div>
      </div>

      <!-- CASE STUDIES -->
      <div class="cases-section">
        <div class="div-label">Case studies</div>
        <h2>Problems solved in production.</h2>
        <div class="cases">

          <div class="case">
            <div class="case-top">
              <span class="case-industry">Enterprise · Retail</span>
            </div>
            <h3>Azure Landing Zone Migration</h3>
            <div class="case-metric">
              <span class="metric-val">60%</span>
              <span class="metric-lbl">cost reduction</span>
            </div>
            <p>Designed and migrated a 40-service estate to an enterprise landing zone — hub-and-spoke, Policy-as-Code, unified monitoring. Delivered in 8 weeks.</p>
            <div class="case-tags">
              <span>Azure</span><span>Bicep</span><span>Policy</span><span>FinOps</span>
            </div>
          </div>

          <div class="case">
            <div class="case-top">
              <span class="case-industry">Scale-up · FinTech</span>
            </div>
            <h3>DevOps Platform Transformation</h3>
            <div class="case-metric">
              <span class="metric-val">3×</span>
              <span class="metric-lbl">faster deployments</span>
            </div>
            <p>Replaced a legacy Jenkins cluster with GitHub Actions + Azure DevOps, added quality gates, and automated IaC drift detection. Zero outages for 6 months.</p>
            <div class="case-tags">
              <span>GitHub Actions</span><span>Terraform</span><span>SonarQube</span>
            </div>
          </div>

          <div class="case">
            <div class="case-top">
              <span class="case-industry">Mid-market · SaaS</span>
            </div>
            <h3>AI Enablement for Engineering</h3>
            <div class="case-metric">
              <span class="metric-val">40%</span>
              <span class="metric-lbl">productivity gain</span>
            </div>
            <p>Rolled out Claude-based internal tooling — codebase Q&amp;A, IaC generator, incident summariser — across a 60-engineer team. 4-week engagement.</p>
            <div class="case-tags">
              <span>Claude</span><span>MCP</span><span>RAG</span><span>Python</span>
            </div>
          </div>

          <div class="case">
            <div class="case-top">
              <span class="case-industry">Enterprise · Healthcare</span>
            </div>
            <h3>Multi-cloud FinOps Programme</h3>
            <div class="case-metric">
              <span class="metric-val">$2M</span>
              <span class="metric-lbl">saved annually</span>
            </div>
            <p>Implemented tagging taxonomy, right-sizing automation, and reserved-instance strategy across Azure + AWS. Ongoing cost anomaly alerting keeps savings compounding.</p>
            <div class="case-tags">
              <span>Azure</span><span>AWS</span><span>FinOps</span><span>Terraform</span>
            </div>
          </div>

        </div>
        <div style="margin-top:24px">
          <a class="btn ghost" href="/projects">See all projects →</a>
        </div>
      </div>

      <!-- SERVICE TEASERS -->
      <div class="teaser-section">
        <div class="div-label">Services</div>
        <div class="teaser">
          <a href="/services" class="t-card">
            <div class="ico">CL</div>
            <h3>Cloud architecture</h3>
            <p>Landing zones, migrations, well-architected reviews — Azure-first, multi-cloud aware.</p>
            <span class="more">See services</span>
          </a>
          <a href="/services" class="t-card">
            <div class="ico">DO</div>
            <h3>DevOps &amp; automation</h3>
            <p>Azure DevOps, GitHub Actions, Terraform, Bicep. Pipelines that survive Mondays.</p>
            <span class="more">See services</span>
          </a>
          <a href="/services" class="t-card">
            <div class="ico">AI</div>
            <h3>AI &amp; vibe coding</h3>
            <p>Practical use of Claude / Copilot, custom skills, internal AI tooling — without losing taste.</p>
            <span class="more">See services</span>
          </a>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero { padding-top: 64px; padding-bottom: 24px; }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 48px;
    align-items: center;
  }
  @media (max-width: 820px) {
    .hero-grid { grid-template-columns: 1fr; gap: 36px; }
  }

  .hero-text { display: flex; flex-direction: column; }

  .hero h1 em { font-style: italic; font-weight: 300; color: var(--navy); }
  .hero h1 u  {
    text-decoration: none;
    background-image: linear-gradient(transparent 60%, rgba(201,169,97,0.45) 60%);
    padding: 0 2px;
  }

  /* Trust strip */
  .trust-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px 10px;
    margin-top: 22px;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--gold-deep);
    letter-spacing: 0.02em;
  }
  .trust-strip .sep { color: var(--line); font-weight: 400; }

  .meta     { margin-top: 22px; display: flex; flex-wrap: wrap; gap: 10px; }
  .cta-row  { margin-top: 22px; display: flex; flex-wrap: wrap; gap: 12px; }

  /* Portrait */
  .hero-portrait-wrap {
    display: flex;
    justify-content: center;
  }
  @media (max-width: 820px) {
    .hero-portrait-wrap { order: -1; }
  }

  .portrait-frame {
    position: relative;
    width: 100%;
    max-width: 320px;
  }
  .portrait-inner {
    aspect-ratio: 4/5;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    overflow: hidden;
    position: relative;
  }

  /* Real photo */
  .portrait-inner .photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 22%;
    z-index: 1;
    transition: filter 0.35s ease;
  }
  .portrait-inner:hover .photo {
    filter: saturate(1.05) contrast(1.02);
  }

  /* DK watermark behind photo */
  .portrait-watermark {
    position: absolute;
    right: -16px;
    bottom: -40px;
    font-family: var(--serif);
    font-weight: 400;
    font-size: 200px;
    color: var(--navy-soft);
    letter-spacing: -0.06em;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    opacity: 0.15;
  }

  /* Gold corner decoration (top-right) */
  .portrait-corner-tl {
    position: absolute;
    top: -8px;
    right: -8px;
    width: 48px;
    height: 48px;
    border-top: 3px solid var(--gold);
    border-right: 3px solid var(--gold);
    border-radius: 0 var(--r-md) 0 0;
    pointer-events: none;
  }

  /* Navy accent square (bottom-left) */
  .portrait-accent {
    position: absolute;
    bottom: -10px;
    left: -10px;
    width: 32px;
    height: 32px;
    background: var(--navy);
    border-radius: 6px;
    pointer-events: none;
  }

  /* ── Bento grid ── */
  .bento {
    margin-top: 64px;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: minmax(110px, auto);
    gap: 14px;
  }
  .bento .card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 22px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 10px;
    transition: transform 0.15s, border-color 0.15s;
  }
  .bento .card:hover { transform: translateY(-2px); border-color: var(--navy); }
  .bento .span2 { grid-column: span 2; }
  .bento .span4 { grid-column: span 4; }
  .bento .row2  { grid-row: span 2; }
  .bento .num { font-family: var(--serif); font-size: 48px; line-height: 1; letter-spacing: -0.03em; color: var(--navy); font-weight: 400; }
  .bento .lbl { font-size: 12px; color: var(--muted); letter-spacing: 0.04em; }
  .bento .navy { background: var(--navy); color: var(--paper); border-color: var(--navy); }
  .bento .navy .num { color: var(--paper); }
  .bento .navy .lbl { color: var(--muted-2); }
  .bento .gold { background: var(--gold); color: #1F2A3D; border-color: var(--gold); }
  .now-now { display: flex; align-items: center; gap: 8px; font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: #1F2A3D; font-weight: 500; }
  .blink { width: 8px; height: 8px; border-radius: 50%; background: #1F2A3D; animation: blink 1.4s ease-in-out infinite; display: inline-block; }
  @media (max-width: 780px) {
    .bento { grid-template-columns: repeat(2, 1fr); }
    .bento .span2, .bento .span4 { grid-column: span 2; }
  }

  /* ── Case studies ── */
  .cases-section { margin-top: 96px; }
  .cases {
    margin-top: 32px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  @media (max-width: 680px) { .cases { grid-template-columns: 1fr; } }

  .case {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.15s, transform 0.15s;
  }
  .case:hover { border-color: var(--navy); transform: translateY(-2px); }

  .case-top { display: flex; align-items: center; }
  .case-industry {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-deep);
    font-weight: 600;
  }

  .case h3 {
    font-family: var(--serif);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.2;
    color: var(--ink);
  }

  .case-metric {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .metric-val {
    font-family: var(--serif);
    font-size: 40px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--navy);
  }
  html[data-theme="dark"] .metric-val { color: var(--gold); }
  .metric-lbl {
    font-size: 13px;
    color: var(--muted);
    font-weight: 500;
  }

  .case p { font-size: 14.5px; color: var(--muted); margin: 0; line-height: 1.55; }

  .case-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }
  .case-tags span {
    font-size: 11px;
    background: var(--code);
    color: var(--ink);
    padding: 3px 10px;
    border-radius: 6px;
    font-weight: 500;
  }

  /* ── Service teasers ── */
  .teaser-section { margin-top: 80px; }
  .teaser { margin-top: 24px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .t-card {
    padding: 26px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    transition: border-color 0.15s, transform 0.15s;
    display: flex;
    flex-direction: column;
  }
  .t-card:hover { border-color: var(--navy); transform: translateY(-2px); }
  .t-card .ico {
    width: 34px; height: 34px; border-radius: 8px;
    background: var(--navy); color: var(--gold);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--serif); font-size: 14px; font-weight: 500;
    margin-bottom: 14px; letter-spacing: -0.04em;
  }
  .t-card h3 { margin-bottom: 6px; }
  .t-card p { color: var(--muted); font-size: 14.5px; flex: 1; }
  .more {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 14px; font-size: 13px; color: var(--navy); font-weight: 500;
  }
  .more::after { content: "→"; transition: transform 0.15s; }
  .t-card:hover .more::after { transform: translateX(3px); }
  @media (max-width: 780px) { .teaser { grid-template-columns: 1fr; } }
</style>
