---
import BaseLayout from '../components/BaseLayout.astro';
import { t, type Lang } from '../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
---

<BaseLayout
  lang={lang}
  title={`${t(lang, 'services.label')} — ${t(lang, 'meta.site_title')}`}
  description={t(lang, 'services.lead')}
>
  <section class="page">
    <div class="wrap">
      <div class="div-label">{t(lang, 'services.label')}</div>
      <h2>{t(lang, 'services.title')}</h2>
      <p class="lead muted" style="margin-top:14px">{t(lang, 'services.lead')}</p>

      <!-- 3-tier pricing -->
      <div class="tiers" style="margin-top:48px">

        <!-- Tier 1: Free -->
        <div class="tier">
          <div class="tier-badge">{t(lang, 'services.tier_free_badge')}</div>
          <div class="tier-price">{t(lang, 'services.tier_free_price')}</div>
          <h3 class="tier-title">{t(lang, 'services.tier_free_title')}</h3>
          <p class="tier-desc">{t(lang, 'services.tier_free_desc')}</p>
          <ul class="tier-list">
            <li>{t(lang, 'services.tier_free_b1')}</li>
            <li>{t(lang, 'services.tier_free_b2')}</li>
            <li>{t(lang, 'services.tier_free_b3')}</li>
          </ul>
          <a class="btn ghost" href="https://calendly.com/dklevakin" target="_blank" rel="noopener" style="margin-top:auto">
            {t(lang, 'services.tier_free_cta')} →
          </a>
        </div>

        <!-- Tier 2: Architecture Review (featured) -->
        <div class="tier featured">
          <div class="tier-badge">{t(lang, 'services.tier_review_badge')}</div>
          <div class="tier-price">{t(lang, 'services.tier_review_price')}</div>
          <h3 class="tier-title">{t(lang, 'services.tier_review_title')}</h3>
          <p class="tier-desc">{t(lang, 'services.tier_review_desc')}</p>
          <ul class="tier-list">
            <li>{t(lang, 'services.tier_review_b1')}</li>
            <li>{t(lang, 'services.tier_review_b2')}</li>
            <li>{t(lang, 'services.tier_review_b3')}</li>
            <li>{t(lang, 'services.tier_review_b4')}</li>
            <li>{t(lang, 'services.tier_review_b5')}</li>
          </ul>
          <a class="btn gold" href="mailto:dlklevakin@gmail.com?subject=Architecture+Review+enquiry" style="margin-top:auto">
            {t(lang, 'services.tier_review_cta')} →
          </a>
        </div>

        <!-- Tier 3: Embedded Architect -->
        <div class="tier">
          <div class="tier-badge">{t(lang, 'services.tier_embed_badge')}</div>
          <div class="tier-price">{t(lang, 'services.tier_embed_price')}</div>
          <h3 class="tier-title">{t(lang, 'services.tier_embed_title')}</h3>
          <p class="tier-desc">{t(lang, 'services.tier_embed_desc')}</p>
          <ul class="tier-list">
            <li>{t(lang, 'services.tier_embed_b1')}</li>
            <li>{t(lang, 'services.tier_embed_b2')}</li>
            <li>{t(lang, 'services.tier_embed_b3')}</li>
            <li>{t(lang, 'services.tier_embed_b4')}</li>
          </ul>
          <a class="btn ghost" href="mailto:dlklevakin@gmail.com?subject=Embedded+Architect+enquiry" style="margin-top:auto">
            {t(lang, 'services.tier_embed_cta')} →
          </a>
        </div>

      </div>

      <!-- Service detail grid -->
      <div class="div-label" style="margin-top:72px">{t(lang, 'services.what_label')}</div>
      <div class="svc">
        <div class="s">
          <div class="ico">CL</div>
          <h3>{t(lang, 'teasers.cloud_title')}</h3>
          <p>Azure-first, multi-cloud aware. I'll help you choose, design and de-risk — using Well-Architected and Cloud Adoption frameworks as the backbone.</p>
          <ul>
            <li>Architecture review (1–2 weeks)</li>
            <li>Landing zone &amp; tenant design (Azure / AWS / GCP)</li>
            <li>Migration roadmap &amp; cost-optimization (FinOps)</li>
            <li>ASR &amp; backup strategies for on-prem → cloud</li>
          </ul>
        </div>
        <div class="s">
          <div class="ico">DO</div>
          <h3>{t(lang, 'teasers.devops_title')}</h3>
          <p>Pipelines that survive Mondays. ARM, Bicep, Terraform, Ansible. Azure DevOps and GitHub Actions, with the boring quality gates that actually catch things.</p>
          <ul>
            <li>CI/CD assessment &amp; redesign</li>
            <li>IaC modules (Terraform / Bicep / ARM)</li>
            <li>SonarQube · Artifactory · Ansible integration</li>
            <li>Internal developer platform setup</li>
          </ul>
        </div>
        <div class="s">
          <div class="ico">AI</div>
          <h3>{t(lang, 'teasers.ai_title')}</h3>
          <p>How to actually use Claude / Copilot in day-to-day engineering, where to deploy custom skills, and how to ship faster without losing taste.</p>
          <ul>
            <li>AI workflow audit for engineering teams</li>
            <li>Custom Claude / MCP skills tailored to your stack</li>
            <li>Internal AI tooling (RAG over docs, code Q&amp;A)</li>
            <li>Hands-on enablement workshop</li>
          </ul>
        </div>
        <div class="s">
          <div class="ico">CO</div>
          <h3>Coaching &amp; mentoring</h3>
          <p>Some architecture problems are people problems. As a certified NLP Master Practitioner and professional coach, I work with leads and architects on the human layer.</p>
          <ul>
            <li>1:1 coaching for Cloud / DevOps leads</li>
            <li>Career-path mentoring (engineer → architect)</li>
            <li>Team workshops on technical decision making</li>
            <li>Interviewer / hiring-process coaching</li>
          </ul>
        </div>
      </div>

      <div class="svc-cta">
        <div>
          <h3>{t(lang, 'services.cta_title')}</h3>
          <p>{t(lang, 'services.cta_body')}</p>
        </div>
        <a class="btn gold" href="mailto:dlklevakin@gmail.com">{t(lang, 'services.cta_btn')} →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Tier pricing */
  .tiers { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; align-items: stretch; }
  @media (max-width: 820px) { .tiers { grid-template-columns: 1fr; } }
  .tier {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: border-color 0.15s, transform 0.15s;
  }
  .tier:hover { border-color: var(--navy); transform: translateY(-2px); }
  .tier.featured {
    background: var(--navy);
    border-color: var(--navy);
    color: var(--paper);
    position: relative;
    transform: none;
  }
  .tier.featured:hover { transform: translateY(-2px); }
  .tier-badge { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 600; color: var(--gold-deep); }
  .tier.featured .tier-badge { color: var(--gold); }
  .tier-price { font-family: var(--serif); font-size: clamp(32px, 4vw, 44px); font-weight: 400; line-height: 1; letter-spacing: -0.03em; color: var(--navy); }
  .tier.featured .tier-price { color: var(--paper); }
  .tier-title { font-family: var(--serif); font-size: 22px; font-weight: 500; letter-spacing: -0.015em; line-height: 1.2; color: var(--ink); }
  .tier.featured .tier-title { color: var(--paper); }
  .tier-desc { font-size: 14.5px; color: var(--muted); line-height: 1.55; margin: 0; }
  .tier.featured .tier-desc { color: var(--muted-2); }
  .tier-list { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--line); padding-top: 16px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .tier.featured .tier-list { border-top-color: rgba(255,255,255,0.12); }
  .tier-list li { font-size: 13.5px; color: var(--ink); display: flex; gap: 10px; align-items: baseline; line-height: 1.45; }
  .tier.featured .tier-list li { color: var(--paper); opacity: 0.88; }
  .tier-list li::before { content: ""; flex: 0 0 6px; width: 6px; height: 6px; border-radius: 50%; background: var(--gold); transform: translateY(2px); }
  .tier.featured .btn.ghost { border-color: rgba(255,255,255,0.25); color: var(--paper); }
  .tier.featured .btn.ghost:hover { background: rgba(255,255,255,0.1); }

  /* Service detail cards */
  .svc { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin-top: 16px; }
  @media (max-width: 780px) { .svc { grid-template-columns: 1fr; } }
  .s { padding: 28px; background: var(--surface); border: 1px solid var(--line); border-radius: var(--r-lg); display: flex; flex-direction: column; gap: 14px; }
  .ico { width: 40px; height: 40px; border-radius: 9px; background: var(--navy); color: var(--gold); display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-size: 15px; font-weight: 500; letter-spacing: -0.04em; }
  .s h3 { font-size: 22px; font-family: var(--serif); font-weight: 500; letter-spacing: -0.015em; }
  .s p  { color: var(--muted); font-size: 14.5px; margin: 0; }
  .s ul { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--line); padding-top: 14px; display: flex; flex-direction: column; gap: 6px; }
  .s ul li { font-size: 13.5px; color: var(--ink); display: flex; gap: 10px; align-items: baseline; }
  .s ul li::before { content: ""; flex: 0 0 6px; width: 6px; height: 6px; border-radius: 50%; background: var(--gold); transform: translateY(2px); }

  /* CTA strip */
  .svc-cta { margin-top: 34px; padding: 30px; background: var(--navy); color: var(--paper); border-radius: var(--r-lg); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 18px; }
  .svc-cta h3 { color: var(--paper); font-family: var(--serif); font-size: 24px; font-weight: 400; margin: 0; }
  .svc-cta p  { color: var(--muted-2); margin: 6px 0 0; font-size: 14.5px; max-width: 520px; }
</style>
