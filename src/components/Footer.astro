---
import { getLang, t } from '../i18n';

const year = new Date().getFullYear();
const lang = getLang(Astro.url);
---

<footer class="site">
  <div class="wrap row">
    <div class="brand">
      <!-- Solid Pivot mark — navy-badge variant; badge bg matches footer's --navy, leaving only the marks visible -->
      <img src="/assets/logos/logo-mark-dark.svg" alt="" width="32" height="32" />
      <span class="brand-name">
        {t(lang, 'meta.site_title')}
        <span class="sub">{t(lang, 'footer.tagline')}</span>
      </span>
    </div>
    <div class="legal">
      © {year} · {t(lang, 'footer.legal')} ·
      <a href="https://github.com/dklevakin" target="_blank" rel="noopener">github.com/dklevakin</a>
    </div>
  </div>
</footer>

<style>
  footer.site {
    background: var(--navy);
    color: var(--muted-2);
    padding: 48px 0;
    font-size: 13px;
    margin-top: 80px;
  }
  footer.site .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .brand-name {
    font-weight: 600;
    font-size: 14px;
    /* Footer bg is always var(--navy). In dark mode --paper flips to near-black,
       so use a fixed cream that stays legible against the always-dark footer. */
    color: #F4F1EA;
  }
  .brand-name .sub {
    display: block;
    font-size: 11px;
    color: var(--muted-2);
    letter-spacing: 0.1em;
    font-weight: 400;
    margin-top: 2px;
  }
  footer.site a { color: var(--muted-2); }
  footer.site a:hover { color: var(--gold); }
  .legal { font-size: 12px; }
</style>
