---
const year = new Date().getFullYear();
---

<footer class="site">
  <div class="wrap row">
    <div class="brand">
      <!-- Solid Pivot — paper/gold on navy background (footer is already navy) -->
      <svg width="30" height="29" viewBox="0 0 104 100" aria-hidden="true">
        <!-- D spine: three paper circles -->
        <circle cx="26" cy="26" r="6" fill="#F4F1EA"/>
        <circle cx="26" cy="50" r="6" fill="#F4F1EA"/>
        <circle cx="26" cy="74" r="6" fill="#F4F1EA"/>
        <!-- D bezier curve -->
        <path d="M26 26 Q56 26 56 50 Q56 74 26 74" stroke="#F4F1EA" stroke-width="3" fill="none"/>
        <!-- Pivot (large gold circle) -->
        <circle cx="58" cy="50" r="9" fill="#C9A961"/>
        <!-- K branches: two gold circles -->
        <circle cx="78" cy="26" r="6" fill="#C9A961"/>
        <circle cx="78" cy="74" r="6" fill="#C9A961"/>
        <!-- K lines -->
        <line x1="58" y1="50" x2="78" y2="26" stroke="#C9A961" stroke-width="3"/>
        <line x1="58" y1="50" x2="78" y2="74" stroke="#C9A961" stroke-width="3"/>
      </svg>
      <span class="brand-name">
        Dmytro Klevakin
        <span class="sub">klevakin.com</span>
      </span>
    </div>
    <div class="legal">
      © {year} · Built quietly in Dnipro ·
      <a href="https://github.com/dklevakin" target="_blank" rel="noopener">github.com/dklevakin</a>
    </div>
  </div>
</footer>

<style>
  footer.site {
    background: var(--navy);
    color: var(--muted-2);
    padding: 48px 0;
    font-size: 13px;
    margin-top: 80px;
  }
  footer.site .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .brand-name {
    font-weight: 600;
    font-size: 14px;
    color: var(--paper);
  }
  .brand-name .sub {
    display: block;
    font-size: 11px;
    color: var(--muted-2);
    letter-spacing: 0.1em;
    font-weight: 400;
    margin-top: 2px;
  }
  footer.site a { color: var(--muted-2); }
  footer.site a:hover { color: var(--gold); }
  .legal { font-size: 12px; }
</style>
