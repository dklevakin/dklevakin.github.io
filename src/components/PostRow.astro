---
interface Props {
  date:     Date;
  title:    string;
  category: string;
  href:     string;
}
const { date, title, category, href } = Astro.props;

const dateStr = date.toISOString().slice(0, 10); // YYYY-MM-DD
---

<a class="it" href={href}>
  <div class="d">{dateStr}</div>
  <div class="t">{title}</div>
  <div class="cat">{category}</div>
</a>

<style>
  .it {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 16px;
    padding: 18px 0;
    border-bottom: 1px solid var(--line);
    align-items: baseline;
    transition: color 0.15s;
  }
  .it:hover .t { color: var(--navy); }
  html[data-theme="dark"] .it:hover .t { color: var(--gold); }
  .d {
    font-variant-numeric: tabular-nums;
    color: var(--muted);
    font-size: 13px;
    font-family: var(--mono);
  }
  .t { font-size: 15.5px; font-weight: 500; }
  .cat {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold-deep);
    font-weight: 600;
    white-space: nowrap;
  }
</style>
