---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout
  title="Music — Dmytro Klevakin"
  description="Live-coded ambient music with Strudel — JavaScript pattern language that runs in the browser. Recordings on SoundCloud."
>
  <section class="page">
    <div class="wrap">
      <div class="div-label">Music life</div>
      <div class="music">
        <div class="grid">
          <div>
            <h2 style="margin:0">Code is the instrument.</h2>
            <div class="tg">
              <span>Strudel REPL</span>
              <span>Live coding</span>
              <span>Ambient · Electronic</span>
            </div>
            <p>
              Outside engineering I write and perform live-coded music with
              <strong style="color:var(--paper)">Strudel</strong> — a JavaScript pattern language
              that runs in the browser. A few patches and recordings live below; more on SoundCloud.
            </p>
            <div class="links">
              <a class="btn gold" href="https://strudel.cc/?example" target="_blank" rel="noopener">Open Strudel REPL →</a>
              <a class="btn ghost" style="border-color:var(--navy-2);color:var(--paper)"
                 href="https://soundcloud.com/dklevakin" target="_blank" rel="noopener">SoundCloud</a>
            </div>
          </div>
          <div class="repl" aria-label="Strudel patch preview">
            <div class="row"><span></span><span></span><span></span></div>
            <span class="ln"><span class="c">// dmytro · ambient pattern</span></span>
            <span class="ln"><span class="k">setcps</span>(<span class="s">0.5</span>)</span>
            <span class="ln"><span class="k">stack</span>(</span>
            <span class="ln">&nbsp;&nbsp;<span class="s">"~ bd ~ bd"</span>.s(<span class="s">"bd:5"</span>),</span>
            <span class="ln">&nbsp;&nbsp;<span class="s">"hh*8"</span>.gain(<span class="s">0.4</span>),</span>
            <span class="ln">&nbsp;&nbsp;<span class="k">note</span>(<span class="s">"&lt;c2 g1 a1 f1&gt;"</span>).s(<span class="s">"sawtooth"</span>)</span>
            <span class="ln">&nbsp;&nbsp;&nbsp;&nbsp;.cutoff(<span class="s">800</span>).resonance(<span class="s">12</span>)</span>
            <span class="ln">)</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .music {
    background: var(--navy);
    color: var(--paper);
    padding: 64px 28px;
    border-radius: var(--r-lg);
    margin-top: 8px;
  }
  .music .grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 42px;
    max-width: var(--maxw);
    margin: 0 auto;
    align-items: center;
  }
  @media (max-width: 780px) { .music .grid { grid-template-columns: 1fr; } }
  .music h2 { color: var(--paper); font-family: var(--serif); }
  .music p  { color: var(--muted-2); font-size: 15px; max-width: 480px; }
  .tg { margin: 14px 0 22px; display: flex; flex-wrap: wrap; gap: 8px; }
  .tg span { font-size: 12px; color: var(--muted-2); background: var(--navy-2); padding: 5px 12px; border-radius: 999px; }
  .links { display: flex; flex-wrap: wrap; gap: 10px; }

  .repl {
    background: #0B0E14;
    border: 1px solid var(--navy-2);
    border-radius: var(--r-md);
    padding: 22px;
    font-family: var(--mono);
    font-size: 12.5px;
    color: #9CA3AF;
    line-height: 1.7;
  }
  .repl .row { display: flex; gap: 6px; margin-bottom: 12px; }
  .repl .row span { width: 10px; height: 10px; border-radius: 50%; background: #27272A; }
  .ln { display: block; }
  .k  { color: var(--gold); }
  .s  { color: #86EFAC; }
  .c  { color: #6B7280; }
</style>
