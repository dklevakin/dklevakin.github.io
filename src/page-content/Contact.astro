---
import BaseLayout from '../components/BaseLayout.astro';
import { t, type Lang } from '../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
---

<BaseLayout
  lang={lang}
  title={`${t(lang, 'contact.label')} — ${t(lang, 'meta.site_title')}`}
  description={t(lang, 'contact.lead')}
>
  <section class="page">
    <div class="wrap">
      <div class="div-label">{t(lang, 'contact.label')}</div>
      <h2>{t(lang, 'contact.title')}</h2>
      <p class="lead muted" style="margin-top:14px">{t(lang, 'contact.lead')}</p>

      <div class="contact-grid" style="margin-top:32px">

        <!-- Left: direct contacts -->
        <div>
          <div class="email-block">
            <div class="div-label" style="margin-bottom:0">{t(lang, 'contact.email_label')}</div>
            <a class="em" href="mailto:dlklevakin@gmail.com">dlklevakin@gmail.com</a>
            <p class="muted" style="font-size:14px">{t(lang, 'contact.email_helper')}</p>
            <a class="btn gold" href="mailto:dlklevakin@gmail.com" style="margin-top:6px">
              {t(lang, 'contact.email_cta')} →
            </a>
          </div>

          <div class="contact-cards">
            <a class="contact-card" href="https://calendly.com/dklevakin" target="_blank" rel="noopener">
              <div class="cc-icon">📅</div>
              <div>
                <div class="cc-label">{t(lang, 'contact.book_label')}</div>
                <div class="cc-val">calendly.com/dklevakin</div>
              </div>
              <span class="arr">↗</span>
            </a>
            <a class="contact-card" href="https://t.me/dklevakin" target="_blank" rel="noopener">
              <div class="cc-icon tg-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2Z" fill="#29B6F6"/>
                  <path d="M17.414 7.386 15.2 17.4c-.16.72-.59.895-1.196.557l-3.31-2.44-1.597 1.537c-.177.177-.325.325-.666.325l.237-3.367 6.12-5.528c.266-.237-.058-.368-.41-.131L6.33 13.463l-3.253-.988c-.707-.222-.721-.707.148-1.045L16.558 6.36c.589-.215 1.104.131.856 1.026Z" fill="white"/>
                </svg>
              </div>
              <div>
                <div class="cc-label">{t(lang, 'contact.telegram_label')}</div>
                <div class="cc-val">@dklevakin</div>
              </div>
              <span class="arr">↗</span>
            </a>
          </div>
        </div>

        <!-- Right: social links + location -->
        <div>
          <div class="div-label">{t(lang, 'contact.elsewhere_label')}</div>
          <div class="social">
            <a href="https://github.com/dklevakin"           target="_blank" rel="noopener">GitHub <span class="arr">↗</span></a>
            <a href="https://www.linkedin.com/in/dklevakin"  target="_blank" rel="noopener">LinkedIn <span class="arr">↗</span></a>
            <a href="https://x.com/dlklevakin"               target="_blank" rel="noopener">X / Twitter <span class="arr">↗</span></a>
            <a href="https://dev.to/dklevakin"               target="_blank" rel="noopener">DEV.to <span class="arr">↗</span></a>
            <a href="https://soundcloud.com/dklevakin"       target="_blank" rel="noopener">SoundCloud <span class="arr">↗</span></a>
            <a href="https://strudel.cc"                     target="_blank" rel="noopener">Strudel REPL <span class="arr">↗</span></a>
          </div>

          <div class="div-label" style="margin-top:28px">{t(lang, 'contact.location_label')}</div>
          <p class="muted" style="font-size:14px;margin:0" set:html={t(lang, 'contact.location_body')}></p>

          <div class="div-label" style="margin-top:28px">{t(lang, 'contact.response_label')}</div>
          <div class="response-badges">
            <span class="rbadge"><span class="dot live"></span>{t(lang, 'contact.response_email')}</span>
            <span class="rbadge"><span class="dot"></span>{t(lang, 'contact.response_linkedin')}</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; }
  @media (max-width: 780px) { .contact-grid { grid-template-columns: 1fr; } }

  .email-block { background: var(--surface); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 32px; }
  .em { font-family: var(--serif); font-size: clamp(18px, 2.5vw, 26px); color: var(--navy); font-weight: 400; font-style: italic; display: block; margin: 14px 0; letter-spacing: -0.01em; transition: color 0.15s; }
  .em:hover { color: var(--gold-deep); }
  /* Dark mode: --navy becomes near-black, so swap to light --ink */
  html[data-theme="dark"] .em { color: var(--ink); }
  html[data-theme="dark"] .em:hover { color: var(--gold); }

  .contact-cards { display: flex; flex-direction: column; gap: 10px; margin-top: 16px; }
  .contact-card { display: flex; align-items: center; gap: 14px; padding: 16px 18px; background: var(--surface); border: 1px solid var(--line); border-radius: var(--r-md); transition: border-color 0.15s, transform 0.12s; }
  .contact-card:hover { border-color: var(--navy); transform: translateY(-1px); }
  .cc-icon { font-size: 20px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 24px; height: 24px; }
  .cc-label { font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); font-weight: 500; margin-bottom: 3px; }
  .cc-val { font-family: var(--mono); font-size: 14px; color: var(--ink); font-weight: 500; }
  .contact-card .arr { margin-left: auto; color: var(--muted); font-family: var(--mono); font-size: 14px; }

  .social { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 6px; }
  .social a { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; border: 1px solid var(--line); border-radius: var(--r-md); font-size: 14px; font-weight: 500; background: var(--surface); transition: border-color 0.15s, transform 0.12s; }
  .social a:hover { border-color: var(--navy); transform: translateY(-1px); }
  .arr { color: var(--muted); font-family: var(--mono); font-size: 13px; }

  .response-badges { display: flex; flex-direction: column; gap: 8px; margin-top: 6px; }
  .rbadge { display: inline-flex; align-items: center; gap: 8px; font-size: 13.5px; color: var(--ink); font-weight: 500; }
  .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }
  .dot.live { background: #16A34A; box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.18); }
</style>
