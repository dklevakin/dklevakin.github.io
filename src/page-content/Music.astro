---
import BaseLayout from '../components/BaseLayout.astro';
import { t, type Lang } from '../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;

type TrackKind = 'strudel' | 'youtube' | 'soundcloud';
interface Track {
  kind: TrackKind;
  title: string;        // displayed verbatim, no translation
  captionKey?: string;  // optional i18n key for one-line caption
  url: string;          // iframe src
}

// Note: AGPL applies to @strudel/* npm packages. Iframe embedding is "loose
// coupling" and does not propagate AGPL to this codebase.
const tracks: Track[] = [
  {
    kind: 'strudel',
    title: 'Carol of the Bells',
    captionKey: 'music.carol_caption',
    url: 'https://strudel.cc/#%2BIFtnMyxiZjMsZDRdIFtnMyxiZjMsZDRdIiwKICAifiBbZzMsYmYzLGQ0XSBbZzMsYmYzLGQ0XSIsCiAgIn4gW2czLGJmMyxkNF0gW2czLGJmMyxkNF0iLAogICJ%2BIFtlZjMsZzMsYmYzXSBbZWYzLGczLGJmM10iLAogICJ%%%2FQuiDRgyDQv9GA0LjQutC70LDQtNGWKQogICAgLmhwZigxMjApCiAgICAubGVnYXRvKDAuNTUpCiAgICAuX3NwaXJhbCh7IHN0ZWFkeTogMC45NiB9KQogICAgLmNvbG9yKCJ3aGl0ZSIpCiAgICAuY29sb3IoIndoaXRlIikKCnN0YWNrKGJlbGxzLCBiYXNzLCBjb21wKQ%3D%3D',
  },
  // To add a YouTube video:
  // { kind: 'youtube', title: 'Friday session #3', url: 'https://www.youtube.com/embed/VIDEO_ID' },
  // To add a SoundCloud track (use Share → Embed on soundcloud.com to get the URL):
  // { kind: 'soundcloud', title: 'Ambient mix 01',
  //   url: 'https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/tracks/TRACK_ID&color=%23c9a961&auto_play=false&hide_related=true&show_comments=false&show_user=true' },
];

interface KindMeta {
  label: string;
  minHeight: string;
  allow: string;
  allowFullscreen?: boolean;
  aspectRatio?: string;
}

const kindMeta: Record<TrackKind, KindMeta> = {
  strudel:    { label: t(lang, 'music.kind_strudel'),    minHeight: '560px', allow: 'autoplay' },
  youtube:    { label: t(lang, 'music.kind_youtube'),    minHeight: '0',     allow: 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share', allowFullscreen: true, aspectRatio: '16 / 9' },
  soundcloud: { label: t(lang, 'music.kind_soundcloud'), minHeight: '166px', allow: 'autoplay' },
};
---

<BaseLayout
  lang={lang}
  title={`${t(lang, 'music.label')} — ${t(lang, 'meta.site_title')}`}
  description={t(lang, 'music.lead')}
>
  <section class="page">
    <div class="wrap">
      <div class="div-label">{t(lang, 'music.label')}</div>

      <div class="music-intro">
        <h2 style="margin:0">{t(lang, 'music.title')}</h2>
        <div class="tg">
          <span>Strudel REPL</span>
          <span>Live coding</span>
          <span>Ambient · Electronic</span>
        </div>
        <p>{t(lang, 'music.lead')}</p>
        <div class="links">
          <a class="btn ghost" href="https://soundcloud.com/dklevakin" target="_blank" rel="noopener">
            {t(lang, 'music.soundcloud')} →
          </a>
        </div>
      </div>

      <div class="tracks">
        <div class="div-label">{t(lang, 'music.tracks_label')}</div>
        {tracks.map(track => {
          const meta = kindMeta[track.kind];
          const frameStyle = meta.aspectRatio
            ? `aspect-ratio:${meta.aspectRatio};min-height:0;`
            : `min-height:${meta.minHeight};`;
          return (
            <div class="track">
              <div class="track-kind">{meta.label}</div>
              <h3 class="track-title">{track.title}</h3>
              {track.captionKey && <p class="track-caption">{t(lang, track.captionKey)}</p>}
              <iframe
                src={track.url}
                title={`${meta.label} — ${track.title}`}
                loading="lazy"
                allow={meta.allow}
                allowfullscreen={meta.allowFullscreen}
                class="track-frame"
                style={frameStyle}
              ></iframe>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .music-intro h2 { font-family: var(--serif); }
  .music-intro p  { color: var(--muted); font-size: 16px; max-width: 580px; }
  .tg { margin: 14px 0 22px; display: flex; flex-wrap: wrap; gap: 8px; }
  .tg span {
    font-size: 12px;
    color: var(--muted);
    background: var(--code);
    padding: 5px 12px;
    border-radius: 999px;
  }
  .links { display: flex; flex-wrap: wrap; gap: 10px; }

  .tracks {
    margin-top: 64px;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }
  .track { display: flex; flex-direction: column; gap: 8px; }
  .track-kind {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold-deep);
    font-weight: 600;
  }
  .track-title {
    font-family: var(--serif);
    font-weight: 500;
    margin: 0;
  }
  .track-caption {
    color: var(--muted);
    font-size: 14.5px;
    max-width: 640px;
    margin: 0 0 12px;
  }
  .track-frame {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    background: #0B0E14;
    display: block;
  }
  @media (max-width: 780px) {
    .track-frame[style*="min-height:560px"] { min-height: 480px !important; }
  }
</style>
