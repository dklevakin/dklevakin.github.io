---
import BaseLayout from '../components/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
---

<BaseLayout
  title="Projects — Dmytro Klevakin"
  description="Pet projects and things I shipped — Azure landing zones, Claude skills, automation recipes, live-coded music."
>
  <section class="page">
    <div class="wrap">
      <div class="div-label">Projects</div>
      <h2>Pet projects &amp; things I shipped.</h2>
      <p class="lead muted" style="margin-top:14px">
        A mix of side experiments, infra tooling and small AI helpers. Most of these live on GitHub.
      </p>

      <div class="projects" style="margin-top:32px">
        <ProjectCard
          featured={true}
          repo="github.com / dklevakin / azure-landing-zones"
          title="Azure landing-zone blueprints"
          description="Reusable Bicep + Terraform modules for enterprise landing zones — battle-tested patterns for hub-and-spoke, identity, governance and policy-as-code."
          stack={['Bicep', 'Terraform', 'Azure', 'Policy']}
          href="https://github.com/dklevakin"
        />
        <ProjectCard
          repo="github.com / dklevakin / claude-skills"
          title="Claude skills for cloud teams"
          description="Daily-use Claude Skills — file ops, doc generators, codebase Q&A."
          stack={['Claude', 'Python', 'MCP']}
          href="https://github.com/dklevakin"
        />
        <ProjectCard
          repo="github.com / dklevakin / automation-recipes"
          title="Boring tasks, automated"
          description="Snippets — GitHub Actions, n8n flows, shell one-liners — that compound."
          stack={['GitHub Actions', 'n8n', 'Bash']}
          href="https://github.com/dklevakin"
        />
        <ProjectCard
          repo="strudel.cc / patterns"
          title="Live-coded ambient patterns"
          description="JavaScript pattern language that runs in the browser. A few patches I made for late-night sessions."
          stack={['Strudel', 'JavaScript', 'Music']}
          href="https://strudel.cc"
        />
        <ProjectCard
          repo="github.com / dklevakin / klevakin.com"
          title="This site"
          description="Astro v5 static site, hosted on GitHub Pages. Real URLs, content collections, self-hosted fonts."
          stack={['Astro', 'TypeScript', 'GitHub Pages']}
          href="https://github.com/dklevakin/dklevakin.github.io"
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .projects { display: grid; grid-template-columns: repeat(6, 1fr); gap: 14px; }
  @media (max-width: 780px) { :global(.p), :global(.p.feat) { grid-column: span 6 !important; } }
</style>
