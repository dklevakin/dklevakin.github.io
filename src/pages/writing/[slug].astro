---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateStr = post.data.date.toISOString().slice(0, 10);
---

<BaseLayout
  title={`${post.data.title} — Dmytro Klevakin`}
  description={post.data.description}
>
  <section class="page">
    <div class="wrap">
      <div class="back">
        <a href="/writing">← Writing</a>
      </div>

      <header class="post-header">
        <div class="meta-row">
          <span class="cat">{post.data.category}</span>
          <time class="date" datetime={dateStr}>{dateStr}</time>
        </div>
        <h1>{post.data.title}</h1>
        <p class="desc">{post.data.description}</p>
      </header>

      <article class="post-body">
        <Content />
      </article>

      <footer class="post-footer">
        <a href="/writing">← Back to all posts</a>
      </footer>
    </div>
  </section>
</BaseLayout>

<style>
  .back { margin-bottom: 32px; }
  .back a { font-size: 14px; color: var(--muted); font-weight: 500; transition: color 0.15s; }
  .back a:hover { color: var(--navy); }

  .post-header { margin-bottom: 48px; border-bottom: 1px solid var(--line); padding-bottom: 32px; }
  .meta-row { display: flex; align-items: center; gap: 16px; margin-bottom: 16px; }
  .cat { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold-deep); font-weight: 600; }
  .date { font-family: var(--mono); font-size: 13px; color: var(--muted); }
  .post-header h1 { font-size: clamp(28px, 4vw, 48px); line-height: 1.1; font-weight: 400; letter-spacing: -0.025em; }
  .desc { font-size: 18px; color: var(--muted); margin-top: 16px; line-height: 1.5; max-width: 640px; }

  /* Prose styles for Markdown content */
  .post-body { max-width: 680px; }
  .post-body :global(h2) { font-size: 28px; margin: 40px 0 16px; }
  .post-body :global(h3) { font-size: 20px; margin: 32px 0 12px; font-family: var(--sans); }
  .post-body :global(p)  { font-size: 17px; line-height: 1.7; color: var(--ink); margin-bottom: 20px; }
  .post-body :global(a)  { color: var(--navy); text-decoration: underline; text-underline-offset: 3px; }
  .post-body :global(a:hover) { color: var(--gold-deep); }
  .post-body :global(ul), .post-body :global(ol) { padding-left: 24px; margin-bottom: 20px; }
  .post-body :global(li) { font-size: 17px; line-height: 1.7; margin-bottom: 6px; }
  .post-body :global(blockquote) { border-left: 3px solid var(--gold); padding: 4px 0 4px 20px; margin: 28px 0; color: var(--muted); font-style: italic; }
  .post-body :global(pre) { background: var(--navy); color: var(--paper); border-radius: var(--r-md); padding: 22px; overflow-x: auto; margin: 24px 0; }
  .post-body :global(pre code) { background: none; padding: 0; font-size: 14px; }
  .post-body :global(hr) { border: none; border-top: 1px solid var(--line); margin: 40px 0; }

  .post-footer { margin-top: 64px; padding-top: 32px; border-top: 1px solid var(--line); }
  .post-footer a { font-size: 14px; color: var(--muted); font-weight: 500; transition: color 0.15s; }
  .post-footer a:hover { color: var(--navy); }
</style>
