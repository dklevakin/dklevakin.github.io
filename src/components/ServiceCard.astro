---
interface Props {
  icon:        string;
  title:       string;
  description: string;
  items:       string[];
}
const { icon, title, description, items } = Astro.props;
---

<div class="s">
  <div class="ico">{icon}</div>
  <h3>{title}</h3>
  <p>{description}</p>
  <ul>
    {items.map(item => <li>{item}</li>)}
  </ul>
</div>

<style>
  .s {
    padding: 28px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .ico {
    width: 40px;
    height: 40px;
    border-radius: 9px;
    background: var(--navy);
    color: var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.04em;
  }
  h3 {
    font-size: 22px;
    font-family: var(--serif);
    font-weight: 500;
    letter-spacing: -0.015em;
  }
  p {
    color: var(--muted);
    font-size: 14.5px;
    margin: 0;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--line);
    padding-top: 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  li {
    font-size: 13.5px;
    color: var(--ink);
    display: flex;
    gap: 10px;
    align-items: baseline;
  }
  li::before {
    content: '';
    flex: 0 0 6px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
    transform: translateY(2px);
  }
</style>
