---
import Header from './Header.astro';
import Footer from './Footer.astro';
import { getLang, altPath, type Lang } from '../i18n';
import '../styles/global.css';

interface Props {
  title:       string;
  description: string;
  ogImage?:    string;
  /** Optional override; otherwise resolved from Astro.url. */
  lang?:       Lang;
}

const { title, description, ogImage = '/assets/logos/logo-mark-dark-2048.png', lang: langProp } = Astro.props;
const lang: Lang = langProp ?? getLang(Astro.url);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const htmlLang = lang === 'uk' ? 'uk' : 'en';

// Compute alt-language URLs for hreflang tags
const enHref = new URL(altPath(Astro.url.pathname, 'en'), Astro.site);
const ukHref = new URL(altPath(Astro.url.pathname, 'uk'), Astro.site);
---
<!doctype html>
<html lang={htmlLang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Dark mode init — runs before paint to prevent flash -->
  <script is:inline>
    (function () {
      try {
        var saved = localStorage.getItem('klv_theme');
        if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      } catch (e) {}
    })();
  </script>

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- hreflang — point search engines at both language variants -->
  <link rel="alternate" hreflang="en" href={enHref} />
  <link rel="alternate" hreflang="uk" href={ukHref} />
  <link rel="alternate" hreflang="x-default" href={enHref} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={new URL(ogImage, Astro.site)} />
  <meta property="og:locale"      content={lang === 'uk' ? 'uk_UA' : 'en_US'} />
  <meta property="og:locale:alternate" content={lang === 'uk' ? 'en_US' : 'uk_UA'} />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:site"        content="@dklevakin" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={new URL(ogImage, Astro.site)} />

  <!-- Favicon set from design system brand pack (modern → legacy → mobile) -->
  <link rel="icon"          type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon"          type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon"          type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Theme color — controls browser chrome on mobile -->
  <meta name="theme-color" content="#1F2A3D" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#F4F1EA" media="(prefers-color-scheme: light)" />

  <!-- RSS autodiscovery -->
  <link rel="alternate" type="application/rss+xml" title="Dmytro Klevakin" href="/rss.xml" />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
