---
import { getLang, altPath, t, type Lang } from '../i18n';

const pathname = Astro.url.pathname;
const lang: Lang = getLang(Astro.url);
const otherLang: Lang = lang === 'en' ? 'uk' : 'en';
const swapHref = altPath(pathname, otherLang);
const homeHref = lang === 'uk' ? '/uk' : '/';
const prefix = lang === 'uk' ? '/uk' : '';

const navLinks = [
  { href: `${prefix}/`,         key: 'home' },
  { href: `${prefix}/about`,    key: 'about' },
  { href: `${prefix}/services`, key: 'services' },
  { href: `${prefix}/projects`, key: 'projects' },
  { href: `${prefix}/writing`,  key: 'writing' },
  { href: `${prefix}/music`,    key: 'music' },
  { href: `${prefix}/contact`,  key: 'contact' },
];

function isActive(href: string): boolean {
  // Home: only match exact root or /uk
  if (href === '/' || href === '/uk/' || href === '/uk') {
    return pathname === '/' || pathname === '/uk' || pathname === '/uk/';
  }
  // Strip trailing slash for comparison
  const clean = href.replace(/\/$/, '');
  return pathname === clean || pathname.startsWith(clean + '/');
}
---

<header class="site">
  <div class="wrap row">
    <!-- Brand / Logo -->
    <a href={homeHref} class="brand" aria-label={`${t(lang, 'meta.site_title')} — ${t(lang, 'nav.home')}`}>
      <!-- Solid Pivot mark from design system brand pack -->
      <!-- Light theme: transparent variant (navy mark on paper bg) -->
      <img class="logo-light" src="/assets/logos/logo-mark-transparent.svg" alt="" width="36" height="36" />
      <!-- Dark theme: navy-badge variant — cream marks on dark badge, matches dark surface -->
      <img class="logo-dark"  src="/assets/logos/logo-mark-dark.svg" alt="" width="36" height="36" />
      <span class="brand-name">
        {t(lang, 'meta.site_title')}
        <span class="sub">{t(lang, 'meta.site_subtitle')}</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="primary" aria-label="Main navigation">
      {navLinks.map(({ href, key }) => (
        <a href={href} class={isActive(href) ? 'active' : ''} aria-current={isActive(href) ? 'page' : undefined}>
          {t(lang, `nav.${key}`)}
        </a>
      ))}
    </nav>

    <!-- Right controls -->
    <div class="controls">
      <!-- Language switch (anchor — navigates to alt-lang of current page) -->
      <a class="icon-btn lang-btn" href={swapHref} title={`Switch language to ${otherLang.toUpperCase()}`} aria-label="Switch language">
        <span class={lang === 'en' ? 'lang-on' : 'lang-off'}>EN</span><span class="lang-sep">/</span><span class={lang === 'uk' ? 'lang-on' : 'lang-off'}>UA</span>
      </a>

      <!-- Theme toggle -->
      <button class="icon-btn" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
        <span class="icon-light">☀</span>
        <span class="icon-dark">☾</span>
      </button>

      <!-- Hire me CTA -->
      <a class="hire" href="mailto:dlklevakin@gmail.com">
        {t(lang, 'nav.hire')} <span aria-hidden="true">→</span>
      </a>

      <!-- Hamburger (mobile only) -->
      <button class="menubtn" id="menu-toggle" aria-label="Open navigation menu" aria-expanded="false">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile drawer -->
<div class="mobile-backdrop" id="mobile-backdrop" aria-hidden="true"></div>
<nav class="mobile-drawer" id="mobile-drawer" aria-label="Mobile navigation">
  <div class="drawer-header">
    <span class="drawer-brand">{t(lang, 'meta.site_title')}</span>
    <button class="icon-btn" id="drawer-close" aria-label="Close navigation menu">✕</button>
  </div>
  <div class="drawer-links">
    {navLinks.map(({ href, key }) => (
      <a href={href} class={isActive(href) ? 'active' : ''}>{t(lang, `nav.${key}`)}</a>
    ))}
    <a href={swapHref} class="drawer-lang">
      <span class={lang === 'en' ? 'lang-on' : 'lang-off'}>EN</span> / <span class={lang === 'uk' ? 'lang-on' : 'lang-off'}>UA</span>
    </a>
  </div>
  <div class="drawer-footer">
    <a class="btn gold" href="mailto:dlklevakin@gmail.com">{t(lang, 'nav.hire')} →</a>
  </div>
</nav>

<script>
  // ── Theme toggle ──
  const html = document.documentElement;
  const themeBtn = document.getElementById('theme-toggle');

  function getTheme() {
    return html.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
  }

  function setTheme(theme: string) {
    if (theme === 'dark') {
      html.setAttribute('data-theme', 'dark');
    } else {
      html.removeAttribute('data-theme');
    }
    try { localStorage.setItem('klv_theme', theme); } catch (e) {}
  }

  themeBtn?.addEventListener('click', () => {
    setTheme(getTheme() === 'dark' ? 'light' : 'dark');
  });

  // ── Mobile drawer ──
  const menuBtn      = document.getElementById('menu-toggle');
  const drawerClose  = document.getElementById('drawer-close');
  const backdrop     = document.getElementById('mobile-backdrop');
  const drawer       = document.getElementById('mobile-drawer');

  function openDrawer() {
    drawer?.classList.add('open');
    backdrop?.classList.add('open');
    menuBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer?.classList.remove('open');
    backdrop?.classList.remove('open');
    menuBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  menuBtn?.addEventListener('click', openDrawer);
  drawerClose?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);

  // Close on nav link click (SPA-style navigation)
  drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeDrawer));
</script>

<style>
  header.site {
    background: var(--paper);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: saturate(140%) blur(8px);
    transition: background 0.2s, border-color 0.2s;
  }
  header.site .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 14px 0;
  }

  /* Brand */
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .brand-name {
    font-family: var(--sans);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.005em;
    line-height: 1.1;
  }
  .brand-name .sub {
    display: block;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 500;
    margin-top: 2px;
  }

  /* Solid Pivot logo — toggle light/dark variants */
  .logo-light { display: block; }
  .logo-dark  { display: none; }
  html[data-theme="dark"] .logo-light { display: none; }
  html[data-theme="dark"] .logo-dark  { display: block; }

  /* Desktop nav */
  nav.primary {
    display: flex;
    gap: 2px;
    flex-wrap: wrap;
  }
  nav.primary a {
    font-size: 14px;
    color: var(--ink);
    padding: 8px 12px;
    border-radius: 6px;
    font-weight: 500;
    transition: background 0.15s, color 0.15s;
    border-bottom: 2px solid transparent;
  }
  nav.primary a:hover  { background: var(--paper-2); }
  nav.primary a.active { color: var(--navy); border-bottom-color: var(--gold); }
  html[data-theme="dark"] nav.primary a.active { color: var(--ink); }

  /* Controls row */
  .controls {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  /* Icon button (theme toggle, close) */
  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--ink);
    font-size: 16px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .icon-btn:hover { background: var(--paper-2); border-color: var(--navy); }

  /* Show ☀ in dark mode, ☾ in light mode */
  .icon-light { display: none; }
  .icon-dark  { display: inline; }
  html[data-theme="dark"] .icon-light { display: inline; }
  html[data-theme="dark"] .icon-dark  { display: none; }

  /* Language toggle */
  .lang-btn { padding: 0 11px; width: auto; gap: 3px; font-size: 12px; font-weight: 600; letter-spacing: 0.04em; }
  .lang-sep { color: var(--muted); font-weight: 400; }
  .lang-on  { color: var(--ink); }
  .lang-off { color: var(--muted); }

  /* Hire me */
  .hire {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--navy);
    color: var(--paper);
    padding: 9px 16px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    border: 1px solid var(--navy);
    transition: background 0.15s, transform 0.12s;
    white-space: nowrap;
  }
  .hire:hover { background: var(--navy-2); transform: translateY(-1px); }
  html[data-theme="dark"] .hire {
    background: var(--gold);
    color: #1F2A3D;
    border-color: var(--gold);
  }
  html[data-theme="dark"] .hire:hover { background: var(--gold-deep); }

  /* Hamburger button */
  .menubtn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 8px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: transparent;
    cursor: pointer;
  }
  .bar {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--ink);
    border-radius: 2px;
    transition: background 0.15s;
  }

  /* ── Mobile drawer ── */
  .mobile-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 150;
    opacity: 0;
    transition: opacity 0.25s;
  }
  .mobile-backdrop.open { opacity: 1; }

  .mobile-drawer {
    position: fixed;
    top: 0;
    right: -320px;
    width: 300px;
    max-width: 90vw;
    height: 100dvh;
    background: var(--paper);
    border-left: 1px solid var(--line);
    z-index: 200;
    display: flex;
    flex-direction: column;
    padding: 0;
    transition: right 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -4px 0 24px rgba(0,0,0,0.12);
  }
  .mobile-drawer.open { right: 0; }

  .drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--line);
  }
  .drawer-brand {
    font-weight: 600;
    font-size: 15px;
    color: var(--ink);
  }

  .drawer-links {
    display: flex;
    flex-direction: column;
    padding: 12px 0;
    flex: 1;
    overflow-y: auto;
  }
  .drawer-links a {
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
    padding: 14px 24px;
    border-left: 3px solid transparent;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .drawer-links a:hover { background: var(--paper-2); }
  .drawer-links a.active { color: var(--navy); border-left-color: var(--gold); background: var(--paper-2); }
  .drawer-lang {
    margin-top: 12px;
    border-top: 1px solid var(--line);
    font-size: 14px !important;
    font-weight: 600 !important;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .drawer-footer {
    padding: 20px 24px;
    border-top: 1px solid var(--line);
  }
  .drawer-footer .btn { width: 100%; justify-content: center; }

  /* ── Responsive ── */
  @media (max-width: 760px) {
    nav.primary     { display: none; }
    .brand-name .sub { display: none; }
    .menubtn        { display: flex; }
    .mobile-backdrop { display: block; pointer-events: none; }
    .mobile-backdrop.open { pointer-events: auto; }
    .hire { display: none; }
  }
</style>
