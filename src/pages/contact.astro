---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Dmytro Klevakin"
  description="Say hi — easiest way is email. I read everything and reply within a couple of days."
>
  <section class="page">
    <div class="wrap">
      <div class="div-label">Contact</div>
      <h2>Say hi.</h2>
      <p class="lead muted" style="margin-top:14px">
        Easiest way is email — I read everything and reply within a couple of days.
      </p>

      <div class="contact-grid" style="margin-top:32px">

        <!-- Left: direct contacts -->
        <div>
          <div class="email-block">
            <div class="div-label" style="margin-bottom:0">Email</div>
            <a class="em" href="mailto:kl.dmitri@gmail.com">kl.dmitri@gmail.com</a>
            <p class="muted" style="font-size:14px">
              For quick questions LinkedIn DMs work too. For longer conversations,
              just write a paragraph and I'll suggest a time.
            </p>
            <a class="btn gold" href="mailto:kl.dmitri@gmail.com" style="margin-top:6px">
              Open email client →
            </a>
          </div>

          <div class="contact-cards">
            <a class="contact-card" href="https://calendly.com/dklevakin" target="_blank" rel="noopener">
              <div class="cc-icon">📅</div>
              <div>
                <div class="cc-label">Book a call</div>
                <div class="cc-val">calendly.com/dklevakin</div>
              </div>
              <span class="arr">↗</span>
            </a>
            <a class="contact-card" href="tel:+380939454325">
              <div class="cc-icon">📞</div>
              <div>
                <div class="cc-label">Phone / WhatsApp</div>
                <div class="cc-val">+380 93 945 43 25</div>
              </div>
              <span class="arr">↗</span>
            </a>
          </div>
        </div>

        <!-- Right: social links + location -->
        <div>
          <div class="div-label">Elsewhere</div>
          <div class="social">
            <a href="https://github.com/dklevakin"           target="_blank" rel="noopener">GitHub <span class="arr">↗</span></a>
            <a href="https://www.linkedin.com/in/dklevakin"  target="_blank" rel="noopener">LinkedIn <span class="arr">↗</span></a>
            <a href="https://x.com/dklevakin"                target="_blank" rel="noopener">X / Twitter <span class="arr">↗</span></a>
            <a href="https://dev.to/dklevakin"               target="_blank" rel="noopener">DEV.to <span class="arr">↗</span></a>
            <a href="https://soundcloud.com/dklevakin"       target="_blank" rel="noopener">SoundCloud <span class="arr">↗</span></a>
            <a href="https://strudel.cc"                     target="_blank" rel="noopener">Strudel REPL <span class="arr">↗</span></a>
          </div>

          <div class="div-label" style="margin-top:28px">Location &amp; hours</div>
          <p class="muted" style="font-size:14px;margin:0">
            Dnipro, Ukraine · UTC+2 (UTC+3 in summer)<br>
            Usually online 09:00–19:00 · responds same business day.
          </p>

          <div class="div-label" style="margin-top:28px">Response time</div>
          <div class="response-badges">
            <span class="rbadge"><span class="dot live"></span>Email — within 24h</span>
            <span class="rbadge"><span class="dot"></span>LinkedIn — within 48h</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }
  @media (max-width: 780px) { .contact-grid { grid-template-columns: 1fr; } }

  .email-block {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-lg);
    padding: 32px;
  }
  .em {
    font-family: var(--serif);
    font-size: clamp(18px, 2.5vw, 26px);
    color: var(--navy);
    font-weight: 400;
    font-style: italic;
    display: block;
    margin: 14px 0;
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }
  .em:hover { color: var(--gold-deep); }

  /* Contact quick-access cards */
  .contact-cards {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 16px;
  }
  .contact-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    transition: border-color 0.15s, transform 0.12s;
  }
  .contact-card:hover { border-color: var(--navy); transform: translateY(-1px); }
  .cc-icon { font-size: 20px; flex-shrink: 0; }
  .cc-label { font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); font-weight: 500; margin-bottom: 3px; }
  .cc-val { font-family: var(--mono); font-size: 14px; color: var(--ink); font-weight: 500; }
  .contact-card .arr { margin-left: auto; color: var(--muted); font-family: var(--mono); font-size: 14px; }

  /* Social grid */
  .social { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 6px; }
  .social a {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 18px;
    border: 1px solid var(--line);
    border-radius: var(--r-md);
    font-size: 14px; font-weight: 500;
    background: var(--surface);
    transition: border-color 0.15s, transform 0.12s;
  }
  .social a:hover { border-color: var(--navy); transform: translateY(-1px); }
  .arr { color: var(--muted); font-family: var(--mono); font-size: 13px; }

  /* Response time badges */
  .response-badges { display: flex; flex-direction: column; gap: 8px; margin-top: 6px; }
  .rbadge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13.5px;
    color: var(--ink);
    font-weight: 500;
  }
  .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }
  .dot.live { background: #16A34A; box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.18); }
</style>
