---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout
  title="404 — Page not found · Dmytro Klevakin"
  description="This page doesn't exist. Let's get you back on track."
>
  <section class="page not-found">
    <div class="wrap">
      <div class="eyebrow">404</div>
      <h1 style="margin-top:12px">Page not found.</h1>
      <p class="lead muted" style="margin-top:20px">
        This URL doesn't exist. Maybe it moved, maybe it never existed.
        Either way, here's a way out.
      </p>
      <div class="cta-row" style="margin-top:28px">
        <a class="btn gold" href="/">Go home →</a>
        <a class="btn ghost" href="/writing">Read something</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found { padding-top: 80px; }
  .cta-row { display: flex; flex-wrap: wrap; gap: 12px; }
</style>
